# Puerto público del contenedor de la API en el servidor.
API_PORT=3000

# URL exacta donde se publicó el frontend (sin barra final).
FRONTEND_URL=https://tu-sitio.netlify.app

# Base de datos PostgreSQL que ejecutará Docker Compose.
DB_NAME=sunwise
DB_USER=sunwise
DB_PASSWORD=CAMBIA_ESTA_CLAVE_POR_UNA_LARGA_Y_UNICA

# Usa una cadena aleatoria, larga y exclusiva para producción.
JWT_SECRET=CAMBIA_ESTA_CLAVE_POR_UN_SECRETO_DE_AL_MENOS_32_CARACTERES
JWT_EXPIRES_IN=8h
