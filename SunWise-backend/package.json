{
  "name": "sunwise-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:sync": "node src/scripts/syncDatabase.js",
    "db:seed": "node src/scripts/seedDatabase.js",
    "setup": "npm run db:up && npm run db:sync && npm run db:seed",
    "test": "node --test"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7"
  }
}
